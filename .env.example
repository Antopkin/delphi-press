# Delphi Press — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.

# ── Application ───��─────────────────────────────────────────────────────────
SECRET_KEY=              # python3 -c "import secrets; print(secrets.token_urlsafe(48))"
DEBUG=false
LOG_LEVEL=INFO

# ── Database ───────��───────────────────────────────────────��────────────────
DATABASE_URL=sqlite+aiosqlite:///data/delphi_press.db

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=          # Strong random password (used by docker-compose to build REDIS_URL)

# ── Security ───────────────────────────────────��──────────────────────────
FERNET_KEY=              # python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# ── LLM Providers (optional — fallback if user has no keys) ──────────────
OPENROUTER_API_KEY=      # sk-or-... (optional: users provide their own keys)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
YANDEX_FOLDER_ID=        # Yandex Cloud folder ID (optional)
YANDEX_API_KEY=          # Yandex Cloud API key (optional)

# ── Model Routing ──────────────────────────────────────────────────────────
DEFAULT_MODEL_CHEAP=google/gemini-3.1-flash-lite-preview
DEFAULT_MODEL_REASONING=anthropic/claude-opus-4.6
DEFAULT_MODEL_STRONG=anthropic/claude-opus-4.6
DEFAULT_MODEL_RUSSIAN=yandexgpt

# ── Pipeline Tuning ───��───────────────────────��──────────────────────────────
DELPHI_ROUNDS=2
DELPHI_AGENTS=5
MAX_EVENT_THREADS=20
MAX_HEADLINES_PER_PREDICTION=7
QUALITY_GATE_MIN_SCORE=3
PREDICTION_BUDGET_USD=50.0

# ── External APIs (optional) ──────���────────────────────────────────────────
EXA_API_KEY=
JINA_API_KEY=

# ── Server ───────��──────────────────────���──────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1                # Must be 1 for SQLite (single writer)

# ── ARQ Worker ─────────────────────────────────���───────────────────────────
ARQ_MAX_JOBS=10
ARQ_JOB_TIMEOUT=1800     # 30 minutes per prediction
ARQ_CONCURRENCY=2
